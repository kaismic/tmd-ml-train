{
  "name": "TMD Pipeline",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/app",
  "overrideCommand": false,
  "shutdownAction": "stopCompose",

  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "files.exclude": {
          "**/__pycache__": true,
          "**/*.pyc": true
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.black-formatter",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "mhutchie.git-graph"
      ]
    }
  },

  "mounts": [
    // Persist the pip cache across rebuilds to speed up installs
    "source=tmd-pip-cache,target=/root/.cache/pip,type=volume"
  ],

  "postCreateCommand": "pip install --quiet black pylint ipykernel"
}
